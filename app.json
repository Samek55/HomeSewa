{
  "expo": {
    "name": "HomeSewa",
    "slug": "homesewa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/homesewa.png",
    "scheme": "homesewa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pracas.homesewa"
    },
    "android": {
    "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/homesewa-icon-fg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.pracas.homesewa"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/homesewa.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "production",
          "appId": "6088a935-58f5-4645-8290-80633f2bdbc5"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "mr.ded",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ef1e836-b268-4ec8-b6dd-e0e127189eec"
      }
    }
  }
}